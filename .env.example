# ==============================================================================
# PRSense AI - Production Environment Variables Template
# ==============================================================================

# Database Settings (Supabase / Postgres)
DATABASE_URL=postgresql://prsense_user:password@localhost:5432/prsense_db
SPRING_DATASOURCE_URL=jdbc:postgresql://localhost:5432/prsense_db
DB_USER=prsense_user
DB_PASS=password
DB_HOST=localhost
DB_PORT=5432
DB_NAME=prsense_db


# LLM API Credentials
GEMINI_API_KEY=your_gemini_api_key_here
OPENAI_API_KEY=your_openai_api_key_here
LLM_PROVIDER=gemini

# Service Internal Networking URLs
AI_SERVICE_URL=http://localhost:8000
WEBHOOK_BASE_URL=http://localhost:8080
BACKEND_CALLBACK_URL=http://localhost:8080/api/reviews/callback

# Security and API Integration
JWT_SECRET=veryLongSecretKeyWhichShouldBeReplacedInProductionEnvironments99!
ALLOWED_ORIGINS=http://localhost:5173,http://localhost

# GitHub Personal Access Token (for background API usage and repo diff cloning)
GITHUB_TOKEN=your_github_personal_access_token_here

# Frontend Variables (Vite client exposure)
VITE_API_BASE_URL=http://localhost:8080
VITE_AI_BASE_URL=http://localhost:8000
VITE_PROMETHEUS_URL=http://localhost:9090
VITE_GRAFANA_URL=http://localhost:3000
