# PRSense AI Service Environment Configuration

# Provider: 'gemini' or 'openai'
LLM_PROVIDER=gemini

# API Keys
GEMINI_API_KEY=your_gemini_api_key_here
OPENAI_API_KEY=your_openai_api_key_here

# PostgreSQL Database Connection (Either DATABASE_URL or individual params)
DATABASE_URL=postgresql://prsense_user:password@localhost:5432/prsense_db
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=prsense_db
POSTGRES_USER=prsense_user
POSTGRES_PASSWORD=password

# Redis URL (used as Celery Broker and RAG cache)
REDIS_URL=redis://localhost:6379/0

# Spring Boot REST API Callback Url
BACKEND_CALLBACK_URL=http://localhost:8080/api/reviews/callback

# Optional: GitHub Access Token for repository ingestion & commenting
GITHUB_TOKEN=your_github_personal_access_token_here
